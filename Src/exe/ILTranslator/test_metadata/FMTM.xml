                <Calculate Name="FMTM_FindSenserId">
                    <LocalVariable Name="s46_iter" Type="int32_T"/>
                    <For Condition="s46_iter &lt; rtp_POOL_SIZE">
                        <Initial>
                            <Expression Expression="s46_iter = 0"/>
                        </Initial>
                        <Iterator>
                            <Expression Expression="s46_iter++"/>
                        </Iterator>
                        <If Condition="(rtu_SenserId == rtd_SenserIdData[s46_iter]) &amp;&amp; (rtd_SenserIdUsed[s46_iter] == 1) &amp;&amp; (*rtd_FoundId_o == -1)">
                            <Expression Expression="*rty_Out1 = s46_iter"/>
                        </If>
                        <Else>
                            <Expression Expression="*rty_Out1 = *rtd_FoundId_o"/>
                        </Else>
                        <Expression Expression="*rtd_FoundId_o = *rty_Out1"/>
                    </For>
                </Calculate>
            </Schedule>
        </Function>
    </File>
    <File Name="FMTM_data">
        <GlobalVariable Name="FMTM_ConstB" Type="ConstB_FMTM_T" DefaultValue="{1023}"/>
    </File>
</Root>
