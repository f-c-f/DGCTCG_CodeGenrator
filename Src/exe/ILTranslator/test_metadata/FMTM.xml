        <Function Name="FMTM_step" Type="FunctionExec" ReturnType="void">
            <Ref Path="FMTM"/>
            <Input Name="FMTM_M" Type="RT_MODEL_FMTM_T" IsAddress="1"/>
            <Input Name="FMTM_U_SenserId" Type="int32_T"/>
            <Input Name="FMTM_U_Opcode" Type="int32_T"/>
