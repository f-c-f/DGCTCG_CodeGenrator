                            <Expression Expression="FMTM_Error(&amp;FMTM_B-&gt;Merge, &amp;FMTM_B-&gt;Merge1)"/>
                        </If>
                        <Else>
                            <LocalVariable Name="Found" Type="boolean_T"/>
                            <Expression Expression="Found = false"/>
                            <Expression Expression="FoundE = -1"/>
                            <For Condition="s15_iter &lt; 256">
                                <Initial>
                                    <Expression Expression="s15_iter = 0"/>
                                </Initial>
                                <Iterator>
                                    <Expression Expression="s15_iter++"/>
                                </Iterator>
                                <If Condition="(FMTM_DW-&gt;SenserIdUsed[s15_iter] == FMTM_U_SenserId) &amp;&amp; (FMTM_DW-&gt;SenserIdUsed[s15_iter] == 1)">
                                    <Expression Expression="Switch_l4 = true"/>
                                </If>
                                <Else>
                                    <Expression Expression="Switch_l4 = Found"/>
                                </Else>
                                <Expression Expression="Found = Switch_l4"/>
                                <If Condition="(FMTM_DW-&gt;SenserIdUsed[s15_iter] == 0) &amp;&amp; (FoundE == -1)">
                                    <Expression Expression="Switch_m = s15_iter"/>
                                </If>
                                <Else>
                                    <Expression Expression="Switch_m = FoundE"/>
                                </Else>
                                <Expression Expression="FoundE = Switch_m"/>
                            </For>
                            <If Condition="(!Switch_l4) &amp;&amp; (Switch_m != -1)">
                                <Expression Expression="FMTM_B-&gt;Merge = 1"/>
                                <For Condition="FoundE &lt; 256">
                                    <Initial>
                                        <Expression Expression="FoundE = 0"/>
                                    </Initial>
                                    <Iterator>
                                        <Expression Expression="FoundE++"/>
                                    </Iterator>
                                    <LocalVariable Name="rtb_Switch1_f" Type="int32_T"/>
                                    <LocalVariable Name="rtb_Switch_c" Type="int32_T"/>
                                    <LocalVariable Name="rtb_Equal_pi" Type="boolean_T"/>
                                    <Expression Expression="rtb_Equal_pi = (Switch_m == FoundE)"/>
                                    <If Condition="rtb_Equal_pi">
                                        <Expression Expression="rtb_Switch_c = FMTM_U_SenserId"/>
                                    </If>
                                    <Else>
                                        <Expression Expression="rtb_Switch_c = FMTM_DW-&gt;SenserIdData[FoundE]"/>
                                    </Else>
                                    <If Condition="FoundE == 0">
                                        <For Condition="s15_iter &lt; 256">
                                            <Initial>
                                                <Expression Expression="s15_iter = 0"/>
                                            </Initial>
                                            <Iterator>
                                                <Expression Expression="s15_iter++"/>
                                            </Iterator>
                                            <Expression Expression="rtb_Assignment_h[s15_iter] = FMTM_DW-&gt;SenserIdData[s15_iter]"/>
                                        </For>
                                    </If>
                                    <Expression Expression="rtb_Assignment_h[FoundE] = rtb_Switch_c"/>
                                    <For Condition="s15_iter &lt; 256">
                                        <Initial>
                                            <Expression Expression="s15_iter = 0"/>
                                        </Initial>
                                        <Iterator>
                                            <Expression Expression="s15_iter++"/>
                                        </Iterator>
                                        <Expression Expression="FMTM_DW-&gt;SenserIdData[s15_iter] = rtb_Assignment_h[s15_iter]"/>
                                    </For>
                                    <If Condition="rtb_Equal_pi">
                                        <Expression Expression="rtb_Switch1_f = 1"/>
                                    </If>
                                    <Else>
                                        <Expression Expression="rtb_Switch1_f = FMTM_DW-&gt;SenserIdUsed[FoundE]"/>
                                    </Else>
                                    <If Condition="FoundE == 0">
                                        <For Condition="s15_iter &lt; 256">
                                            <Initial>
                                                <Expression Expression="s15_iter = 0"/>
                                            </Initial>
                                            <Iterator>
                                                <Expression Expression="s15_iter++"/>
                                            </Iterator>
                                            <Expression Expression="rtb_Assignment1_o[s15_iter] = FMTM_DW-&gt;SenserIdUsed[s15_iter]"/>
                                        </For>
                                    </If>
                                    <Expression Expression="rtb_Assignment1_o[FoundE] = rtb_Switch1_f"/>
                                    <For Condition="s15_iter &lt; 256">
                                        <Initial>
                                            <Expression Expression="s15_iter = 0"/>
                                        </Initial>
                                        <Iterator>
                                            <Expression Expression="s15_iter++"/>
                                        </Iterator>
                                        <Expression Expression="FMTM_DW-&gt;SenserIdUsed[s15_iter] = rtb_Assignment1_o[s15_iter]"/>
                                    </For>
                                </For>
                                <If Condition="Switch_m == 0">
                                    <Expression Expression="FMTM_B-&gt;Switch_p = 1"/>
                                </If>
                                <ElseIf Condition="Switch_m == 1">
                                    <Expression Expression="FMTM_B-&gt;Switch_p = 2"/>
                                </ElseIf>
                                <ElseIf Condition="Switch_m == 2">
                                    <Expression Expression="FMTM_B-&gt;Switch_p = 3"/>
                                </ElseIf>
                                <Else>
                                    <Expression Expression="FMTM_B-&gt;Switch_p = 4"/>
                                </Else>
                            </If>
                            <Else>
                                <Expression Expression="FMTM_B-&gt;Merge = -10004"/>
                            </Else>
                            <Expression Expression="FMTM_B-&gt;Merge1 = FMTM_B-&gt;Switch_p"/>
                        </Else>
                        <Break/>
                        <Case Value="3"/>
                        <If Condition="FMTM_U_SenserId == 0">
                            <Expression Expression="FMTM_Error(&amp;FMTM_B-&gt;Merge, &amp;FMTM_B-&gt;Merge1)"/>
                        </If>
                        <Else>
                            <Expression Expression="s15_iter = -1"/>
                            <Expression Expression="FoundE = -1"/>
                            <Expression Expression="FMTM_FindSenserId(FMTM_U_SenserId, &amp;FMTM_B-&gt;Switch_l, &amp;s15_iter, FMTM_DW-&gt;SenserIdData, FMTM_DW-&gt;SenserIdUsed, 256)"/>
                            <For Condition="s15_iter &lt; 256">
                                <Initial>
                                    <Expression Expression="s15_iter = 0"/>
                                </Initial>
                                <Iterator>
                                    <Expression Expression="s15_iter++"/>
                                </Iterator>
                                <If Condition="(FMTM_U_TValue == FMTM_DW-&gt;SenserIdData[s15_iter]) &amp;&amp; (FMTM_DW-&gt;SenserIdUsed[s15_iter] == 1) &amp;&amp; (FoundE == -1)">
                                    <Expression Expression="Switch_m = s15_iter"/>
                                </If>
                                <Else>
                                    <Expression Expression="Switch_m = FoundE"/>
                                </Else>
                                <Expression Expression="FoundE = Switch_m"/>
                            </For>
                            <If Condition="(FMTM_B-&gt;Switch_l != -1) &amp;&amp; (Switch_m != -1)">
                                <If Condition="FMTM_U_SenserId == 1">
                                    <Expression Expression="FMTM_B-&gt;Merge = 1001"/>
                                </If>
                                <ElseIf Condition="FMTM_U_SenserId == 2">
                                    <Expression Expression="FMTM_B-&gt;Merge = 1002"/>
                                </ElseIf>
                                <ElseIf Condition="FMTM_U_SenserId == 4">
                                    <Expression Expression="FMTM_B-&gt;Merge = 1004"/>
                                </ElseIf>
                                <ElseIf Condition="FMTM_U_SenserId == 8">
                                    <Expression Expression="FMTM_B-&gt;Merge = 1008"/>
                                </ElseIf>
                                <ElseIf Condition="FMTM_U_SenserId == 16">
                                    <Expression Expression="FMTM_B-&gt;Merge = 1016"/>
                                </ElseIf>
                                <ElseIf Condition="FMTM_U_SenserId == 32">
                                    <Expression Expression="FMTM_B-&gt;Merge = 1032"/>
                                </ElseIf>
                                <Else>
                                    <Expression Expression="FMTM_B-&gt;Merge = FMTM_U_TValue"/>
                                </Else>
                                <Expression Expression="FMTM_B-&gt;OutportBufferForR = FMTM_ConstB.Constant"/>
                            </If>
                            <Else>
                                <Expression Expression="FMTM_B-&gt;Merge = -8"/>
                            </Else>
                            <Expression Expression="FMTM_B-&gt;Merge1 = FMTM_B-&gt;OutportBufferForR"/>
                        </Else>
                        <Break/>
                        <Case Value="4"/>
                        <If Condition="FMTM_U_SenserId == 0">
                            <Expression Expression="FMTM_Error(&amp;FMTM_B-&gt;Merge, &amp;FMTM_B-&gt;Merge1)"/>
                        </If>
                        <Else>
                            <Expression Expression="FoundE = -1"/>
                            <For Condition="s15_iter &lt; 256">
                                <Initial>
                                    <Expression Expression="s15_iter = 0"/>
                                </Initial>
                                <Iterator>
                                    <Expression Expression="s15_iter++"/>
                                </Iterator>
                                <If Condition="(FMTM_U_SenserId == FMTM_DW-&gt;SenserIdData[s15_iter]) &amp;&amp; (FMTM_DW-&gt;SenserIdUsed[s15_iter] == 1) &amp;&amp; (FoundE == -1)">
                                    <Expression Expression="Switch_m = s15_iter"/>
                                </If>
                                <Else>
                                    <Expression Expression="Switch_m = FoundE"/>
                                </Else>
                                <Expression Expression="FoundE = Switch_m"/>
                            </For>
                            <If Condition="Switch_m != -1">
                                <Expression Expression="FMTM_B-&gt;Merge = Switch_m"/>
                                <Expression Expression="FMTM_B-&gt;Merge1 = 1"/>
                            </If>
                            <Else>
                                <Expression Expression="FMTM_B-&gt;Merge = -1"/>
                                <Expression Expression="FMTM_B-&gt;Merge1 = -1"/>
                            </Else>
                        </Else>
                        <Break/>
                        <Case Value="5"/>
                        <If Condition="FMTM_U_SenserId == 0">
                            <Expression Expression="FMTM_Error(&amp;FMTM_B-&gt;Merge, &amp;FMTM_B-&gt;Merge1)"/>
                        </If>
                        <Else>
                            <Expression Expression="FoundE = -1"/>
                            <Expression Expression="FMTM_FindSenserId(FMTM_U_SenserId, &amp;rtb_Switch_l, &amp;FoundE, FMTM_DW-&gt;SenserIdData, FMTM_DW-&gt;SenserIdUsed, 256)"/>
                            <If Condition="rtb_Switch_l == -1">
                                <Expression Expression="FMTM_B-&gt;Merge = -8"/>
                                <Expression Expression="FMTM_B-&gt;Merge1 = 1"/>
                            </If>
                            <Else>
                                <For Condition="FoundE &lt; 256">
                                    <Initial>
                                        <Expression Expression="FoundE = 0"/>
                                    </Initial>
                                    <Iterator>
                                        <Expression Expression="FoundE++"/>
                                    </Iterator>
                                    <LocalVariable Name="rtb_Switch" Type="int32_T"/>
                                    <LocalVariable Name="rtb_Switch1" Type="int32_T"/>
                                    <LocalVariable Name="rtb_Equal" Type="boolean_T"/>
                                    <Expression Expression="rtb_Equal = (FMTM_U_SenserId == FoundE)"/>
                                    <If Condition="rtb_Equal">
                                        <Expression Expression="rtb_Switch = 0"/>
                                    </If>
                                    <Else>
                                        <Expression Expression="rtb_Switch = FMTM_DW-&gt;SenserIdData[FoundE]"/>
                                    </Else>
                                    <If Condition="FoundE == 0">
                                        <For Condition="s15_iter &lt; 256">
                                            <Initial>
                                                <Expression Expression="s15_iter = 0"/>
                                            </Initial>
                                            <Iterator>
                                                <Expression Expression="s15_iter++"/>
                                            </Iterator>
                                            <Expression Expression="rtb_Assignment[s15_iter] = FMTM_DW-&gt;SenserIdData[s15_iter]"/>
                                        </For>
                                    </If>
                                    <Expression Expression="rtb_Assignment[FoundE] = rtb_Switch"/>
                                    <For Condition="s15_iter &lt; 256">
                                        <Initial>
                                            <Expression Expression="s15_iter = 0"/>
                                        </Initial>
                                        <Iterator>
                                            <Expression Expression="s15_iter++"/>
                                        </Iterator>
                                        <Expression Expression="FMTM_DW-&gt;SenserIdData[s15_iter] = rtb_Assignment[s15_iter]"/>
                                    </For>
                                    <If Condition="rtb_Equal">
                                        <Expression Expression="rtb_Switch1 = 0"/>
                                    </If>
                                    <Else>
                                        <Expression Expression="rtb_Switch1 = FMTM_DW-&gt;SenserIdUsed[FoundE]"/>
                                    </Else>
                                    <If Condition="FoundE == 0">
                                        <For Condition="s15_iter &lt; 256">
                                            <Initial>
                                                <Expression Expression="s15_iter = 0"/>
                                            </Initial>
                                            <Iterator>
                                                <Expression Expression="s15_iter++"/>
                                            </Iterator>
                                            <Expression Expression="rtb_Assignment1[s15_iter] = FMTM_DW-&gt;SenserIdUsed[s15_iter]"/>
                                        </For>
                                    </If>
                                    <Expression Expression="rtb_Assignment1[FoundE] = rtb_Switch1"/>
                                    <For Condition="s15_iter &lt; 256">
                                        <Initial>
                                            <Expression Expression="s15_iter = 0"/>
                                        </Initial>
                                        <Iterator>
                                            <Expression Expression="s15_iter++"/>
                                        </Iterator>
                                        <Expression Expression="FMTM_DW-&gt;SenserIdUsed[s15_iter] = rtb_Assignment1[s15_iter]"/>
                                    </For>
                                </For>
                                <Expression Expression="FMTM_B-&gt;Merge = FMTM_U_SenserId"/>
                                <Expression Expression="FMTM_B-&gt;Merge1 = 1"/>
                            </Else>
                        </Else>
                        <Break/>
                    </Switch>
                    <Expression Expression="*FMTM_Y_Res = FMTM_B-&gt;Merge"/>
                    <Expression Expression="*FMTM_Y_R = FMTM_B-&gt;Merge1"/>
                </Calculate>
            </Schedule>
        </Function>
