            <Output Name="FMTM_Y_Res" Type="int32_T"/>
            <Output Name="FMTM_Y_R" Type="int32_T"/>
            <Schedule>
                <Calculate Name="FMTM_step">
                    <LocalVariable Name="FMTM_B" Type="B_FMTM_T" IsAddress="1" DefaultValue="FMTM_M-&gt;blockIO"/>
                    <LocalVariable Name="FMTM_DW" Type="DW_FMTM_T" IsAddress="1" DefaultValue="FMTM_M-&gt;dwork"/>
